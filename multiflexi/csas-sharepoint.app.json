{
    "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
    "schemaVersion": "3.0.0",
    "uuid": "f4d7c8a2-3e9b-4f5a-8c1d-2b6e9f7a4c5d",
    "name": {
        "en": "CSAS to SharePoint",
        "cs": "CSAS to SharePoint"
    },
    "description": {
        "en": "Automates download of bank statements from Česká spořitelna and uploads them to SharePoint.",
        "cs": "Automates download of bank statements from Česká spořitelna and uploads them to SharePoint."
    },
    "tags": [
        "Csas",
        "SharePoint",
        "Office365",
        "Statements",
        "Upload",
        "Banking"
    ],
    "homepage": "https://github.com/Spoje-Net/csas-sharepoint",
    "executable": "csas-sharepoint",
    "environment": {
        "CSAS_API_KEY": {
            "type": "text",
            "description": {
                "en": "API key for CSAS",
                "cs": "API key for CSAS"
            },
            "required": true,
            "category": "Other"
        },
        "CSAS_ACCESS_TOKEN": {
            "type": "text",
            "description": {
                "en": "Access token for CSAS",
                "cs": "Access token for CSAS"
            },
            "required": true,
            "category": "Security"
        },
        "CSAS_ACCOUNT_IBAN": {
            "type": "text",
            "description": {
                "en": "IBAN of the CSAS account",
                "cs": "IBAN of the CSAS account"
            },
            "required": false,
            "category": "Other"
        },
        "CSAS_ACCOUNT_UUID": {
            "type": "text",
            "description": {
                "en": "UUID of the CSAS account",
                "cs": "UUID of the CSAS account"
            },
            "required": false,
            "category": "Other"
        },
        "CSAS_STATEMENT_SCOPE": {
            "type": "select",
            "description": {
                "en": "Time scope for statement download",
                "cs": "Time scope for statement download"
            },
            "defval": "last_month",
            "options": {
                "yesterday": "Yesterday",
                "current_month": "Current Month",
                "last_month": "Last Month",
                "last_two_months": "Last Two Months",
                "previous_month": "Previous Month",
                "two_months_ago": "Two Months Ago",
                "this_year": "This Year"
            },
            "required": false,
            "category": "Other"
        },
        "STATEMENT_FORMAT": {
            "type": "select",
            "description": {
                "en": "Format of downloaded statements",
                "cs": "Format of downloaded statements"
            },
            "defval": "pdf",
            "options": {
                "pdf": "PDF",
                "xml": "XML",
                "xml-data": "XML Data",
                "abo-standard": "ABO Standard",
                "abo-internal": "ABO Internal",
                "csv-comma": "CSV Comma",
                "csv-semicolon": "CSV Semicolon",
                "mt940": "MT940"
            },
            "required": false,
            "category": "Other"
        },
        "CSAS_SANDBOX_MODE": {
            "type": "bool",
            "description": {
                "en": "Enable sandbox mode for CSAS",
                "cs": "Enable sandbox mode for CSAS"
            },
            "defval": false,
            "required": false,
            "category": "Other"
        },
        "CSAS_API_DEBUG": {
            "type": "bool",
            "description": {
                "en": "Enable API debug mode for CSAS",
                "cs": "Enable API debug mode for CSAS"
            },
            "defval": false,
            "required": false,
            "category": "Behavior"
        },
        "OFFICE365_USERNAME": {
            "type": "text",
            "description": {
                "en": "Office 365 Username (for user auth)",
                "cs": "Office 365 Username (for user auth)"
            },
            "required": false,
            "category": "Other"
        },
        "OFFICE365_PASSWORD": {
            "type": "password",
            "description": {
                "en": "Office 365 Password (for user auth)",
                "cs": "Office 365 Password (for user auth)"
            },
            "required": false,
            "category": "Security"
        },
        "OFFICE365_CLIENTID": {
            "type": "text",
            "description": {
                "en": "Office 365 Client ID (for app auth)",
                "cs": "Office 365 Client ID (for app auth)"
            },
            "required": false,
            "category": "Other"
        },
        "OFFICE365_SECRET": {
            "type": "text",
            "description": {
                "en": "Office 365 Secret (deprecated)",
                "cs": "Office 365 Secret (deprecated)"
            },
            "required": false,
            "category": "Security"
        },
        "OFFICE365_CLSECRET": {
            "type": "password",
            "description": {
                "en": "Office 365 Client Secret (for app auth)",
                "cs": "Office 365 Client Secret (for app auth)"
            },
            "required": false,
            "category": "Security"
        },
        "OFFICE365_TENANT": {
            "type": "text",
            "description": {
                "en": "Office 365 Tenant name",
                "cs": "Office 365 Tenant name"
            },
            "required": true,
            "category": "Other"
        },
        "OFFICE365_SITE": {
            "type": "text",
            "description": {
                "en": "SharePoint site name",
                "cs": "SharePoint site name"
            },
            "required": true,
            "category": "Other"
        },
        "OFFICE365_PATH": {
            "type": "text",
            "description": {
                "en": "Target path in SharePoint",
                "cs": "Target path in SharePoint"
            },
            "defval": "bank-statements",
            "required": false,
            "category": "Other"
        },
        "SHAREPOINT_LIBRARY": {
            "type": "text",
            "description": {
                "en": "SharePoint document library",
                "cs": "SharePoint document library"
            },
            "defval": "Documents",
            "required": false,
            "category": "Other"
        },
        "APP_DEBUG": {
            "type": "bool",
            "description": {
                "en": "Enable application debug mode",
                "cs": "Enable application debug mode"
            },
            "defval": false,
            "required": false,
            "category": "Behavior"
        },
        "DEBUG": {
            "type": "bool",
            "description": {
                "en": "Enable general debug mode",
                "cs": "Enable general debug mode"
            },
            "defval": false,
            "required": false,
            "category": "Behavior"
        },
        "EASE_LOGGER": {
            "type": "select",
            "description": {
                "en": "Logging method",
                "cs": "Logging method"
            },
            "defval": "console",
            "options": {
                "console": "Console",
                "syslog": "Syslog",
                "eventlog": "Event Log"
            },
            "required": false,
            "category": "Behavior"
        },
        "RESULT_FILE": {
            "type": "text",
            "description": {
                "en": "Output JSON report file",
                "cs": "Output JSON report file"
            },
            "defval": "csas_sharepoint.json",
            "required": false,
            "category": "Other"
        }
    },
    "artifacts": [
        {
            "name": "SharePoint Upload Log",
            "type": "file",
            "path": "csas_sharepoint.log",
            "description": {
                "en": "Log file containing upload status and SharePoint URLs",
                "cs": "Log file containing upload status and SharePoint URLs"
            }
        }
    ]
}
